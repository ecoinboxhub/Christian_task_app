#!/usr/bin/env sh

# This is a simplified gradlew script for Android build

APP_HOME=$( cd "${0%/*}" && pwd -P )

# Use the maximum available, or set MAX_FD != -1 to use that value.
MAX_FD=maximum

# Determine the Java command to use to start the JVM.
if [ -n "$JAVA_HOME" ] ; then
    JAVACMD=$JAVA_HOME/bin/java
else
    JAVACMD=java
fi

# Execute Gradle
exec "$JAVACMD" -Xmx2048m -jar "$APP_HOME/gradle/wrapper/gradle-wrapper.jar" "$@"
